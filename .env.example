# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bahafix
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong random string (min 32 chars) and paste here
ADMIN_TOKEN=your_secret_admin_token_here

# ─── Email (Gmail) ───────────────────────────────────────────
# Use a dedicated Gmail account for sending notifications
# Enable "App Passwords" in your Google account settings
# and paste the 16-character app password below (not your Gmail login password)
GMAIL_ADDRESS=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Email address that receives enquiry notifications (business owner)
NOTIFY_EMAIL=owner@bahafix.com.au

# ─── App ─────────────────────────────────────────────────────
# Allowed frontend origin for CORS (your website domain)
FRONTEND_ORIGIN=https://bahafix.com.au
