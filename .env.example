# ─── Database ────────────────────────────────────────────────────────────────
# Render provides this automatically when you link a PostgreSQL service.
# For local development, build it manually:
# postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@localhost:5432/bahafix

# ─── Authentication ───────────────────────────────────────────────────────────
# Bearer token for all protected endpoints.
# Generate a strong random string — minimum 32 characters.
# Example (run in terminal): python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=replace_with_your_secure_random_token

# ─── Gmail ───────────────────────────────────────────────────────────────────
# The Gmail account that SENDS the notification emails.
# Must have 2-Step Verification enabled.
# Get an App Password at: myaccount.google.com → Security → App Passwords
GMAIL_ADDRESS=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# The email address that RECEIVES enquiry notifications (business owner).
NOTIFY_EMAIL=owner@bahafix.com.au

# ─── CORS ────────────────────────────────────────────────────────────────────
# Your frontend website domain. Only this origin can call the API.
FRONTEND_ORIGIN=https://bahafix.com.au
